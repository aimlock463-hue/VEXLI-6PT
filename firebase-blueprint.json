{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Stores user profile and subscription data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "premium"] },
        "isAdmin": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "email", "name", "plan", "isAdmin"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User documents keyed by their Firebase Auth UID"
    }
  }
}
