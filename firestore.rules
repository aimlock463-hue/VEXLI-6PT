rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - email: string (required, email format)
    //   - name: string (required)
    //   - plan: string (required, enum: ['free', 'premium'])
    //   - isAdmin: bool (required)
    //   - createdAt: number (required)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isCEO(email) {
      return email == "aimlock463@gmail.com";
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
         (isCEO(request.auth.token.email) && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'email', 'name', 'plan', 'isAdmin', 'createdAt']) &&
             data.id is string &&
             data.email is string &&
             data.name is string && data.name.size() < 100 &&
             data.plan in ['free', 'premium'] &&
             data.isAdmin is bool &&
             data.createdAt is number;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data) && 
                    (
                      (isCEO(request.resource.data.email) && request.resource.data.plan == 'premium' && request.resource.data.isAdmin == true) ||
                      (!isCEO(request.resource.data.email) && request.resource.data.plan == 'free' && request.resource.data.isAdmin == false)
                    );
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    request.resource.data.id == resource.data.id &&
                    (isAdmin() || (request.resource.data.isAdmin == resource.data.isAdmin)) &&
                    (request.resource.data.plan == resource.data.plan || request.resource.data.plan == 'premium');
      allow delete: if isAdmin();
    }
  }
}
